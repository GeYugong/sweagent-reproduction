+def _local_container_network_args() -> list[str]:
+    """Build opt-in Docker arguments for a proxy reachable on the host loopback."""
+    proxy = os.environ.get("SWE_AGENT_CONTAINER_PROXY")
+    if not proxy:
+        return []
+
+    args = ["--network", os.environ.get("SWE_AGENT_DOCKER_NETWORK", "host")]
+    no_proxy = os.environ.get(
+        "SWE_AGENT_CONTAINER_NO_PROXY",
+        "localhost,127.0.0.1,::1",
+    )
+    env_pairs = (
+        ("HTTP_PROXY", proxy),
+        ("HTTPS_PROXY", proxy),
+        ("NO_PROXY", no_proxy),
+        ("CONDA_REMOTE_CONNECT_TIMEOUT_SECS", "60"),
+        ("CONDA_REMOTE_READ_TIMEOUT_SECS", "180"),
+        ("CONDA_REMOTE_MAX_RETRIES", "10"),
+        ("CONDA_DEFAULT_THREADS", "1"),
+        ("CONDA_SOLVER", "classic"),
+    )
+    for name, value in env_pairs:
+        args.extend(["--env", f"{name}={value}"])
+        args.extend(["--env", f"{name.lower()}={value}"])
+    return args
+
